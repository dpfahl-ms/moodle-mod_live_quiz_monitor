{{!
    @template quiz_livequizmonitor/summary_tiles

    Summary status tiles for the live quiz monitor.

    Example context (json):
    {
        "summary": {
            "notstarted": {"label": "Not started", "count": 1, "percent": 25, "statusclass": "border-secondary"},
            "inprogress": {"label": "In progress", "count": 2, "percent": 50, "statusclass": "border-info"},
            "completed": {"label": "Completed", "count": 1, "percent": 25, "statusclass": "border-success"}
        }
    }
}}
<div class="livequizmonitor-summary-tiles row g-3 mb-4" data-region="summary-tiles">
    <div class="col-md-4">
        <div class="card livequizmonitor-tile livequizmonitor-summary-tile border-left {{summary.notstarted.statusclass}}"
             data-action="filter-status"
             data-status="notstarted"
             role="button"
             tabindex="0"
             aria-pressed="false">
            <div class="card-body">
                <div class="livequizmonitor-tile-label">{{summary.notstarted.label}}</div>
                <div class="livequizmonitor-tile-count" data-summary="notstarted">{{summary.notstarted.count}}</div>
                <div class="livequizmonitor-tile-percent" data-summary-pct="notstarted">{{summary.notstarted.percent}}%</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card livequizmonitor-tile livequizmonitor-summary-tile border-left {{summary.inprogress.statusclass}}"
             data-action="filter-status"
             data-status="inprogress"
             role="button"
             tabindex="0"
             aria-pressed="false">
            <div class="card-body">
                <div class="livequizmonitor-tile-label">{{summary.inprogress.label}}</div>
                <div class="livequizmonitor-tile-count" data-summary="inprogress">{{summary.inprogress.count}}</div>
                <div class="livequizmonitor-tile-percent" data-summary-pct="inprogress">{{summary.inprogress.percent}}%</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card livequizmonitor-tile livequizmonitor-summary-tile border-left {{summary.completed.statusclass}}"
             data-action="filter-status"
             data-status="completed"
             role="button"
             tabindex="0"
             aria-pressed="false">
            <div class="card-body">
                <div class="livequizmonitor-tile-label">{{summary.completed.label}}</div>
                <div class="livequizmonitor-tile-count" data-summary="completed">{{summary.completed.count}}</div>
                <div class="livequizmonitor-tile-percent" data-summary-pct="completed">{{summary.completed.percent}}%</div>
            </div>
        </div>
    </div>
</div>
