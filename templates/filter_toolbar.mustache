<div class="livequizmonitor-filter-toolbar mb-3" data-region="filter-toolbar">
    <div class="d-flex flex-wrap align-items-center gap-2">
        <div class="livequizmonitor-search flex-grow-0">
            <input type="search"
                   class="form-control form-control-sm"
                   data-action="search"
                   placeholder="{{filter.searchplaceholder}}"
                   aria-label="{{filter.searchplaceholder}}">
        </div>
        <div class="livequizmonitor-filter-chips d-flex flex-wrap gap-1" role="group" aria-label="{{filter.chipsgrouplabel}}">
            {{#filter.chips}}
                <button type="button"
                        class="btn btn-sm livequizmonitor-filter-chip{{#active}} active{{/active}}"
                        data-action="filter-status"
                        data-status="{{status}}"
                        aria-pressed="{{#active}}true{{/active}}{{^active}}false{{/active}}">
                    {{label}} (<span data-filter-count="{{status}}">{{count}}</span>)
                </button>
            {{/filter.chips}}
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="clear-filters">
            {{filter.clearlabel}}
        </button>
    </div>
</div>
