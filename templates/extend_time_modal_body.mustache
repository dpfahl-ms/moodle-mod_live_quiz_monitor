<div class="livequizmonitor-extend-modal-body">
    <p class="livequizmonitor-extend-description" data-region="extend-description">{{description}}</p>

    <div class="mb-3">
        <div class="font-weight-bold mb-2">{{addtimelabel}}</div>
        <div class="livequizmonitor-extend-presets btn-group" role="group" aria-label="{{addtimelabel}}">
            {{#presets}}
            <button type="button"
                    class="btn btn-outline-secondary livequizmonitor-extend-preset{{#active}} active{{/active}}"
                    data-minutes="{{minutes}}"
                    aria-pressed="{{#active}}true{{/active}}{{^active}}false{{/active}}">
                +{{minutes}}m
            </button>
            {{/presets}}
        </div>
    </div>

    <div>
        <div class="font-weight-bold mb-1" data-region="extend-preview-label">{{previewlabel}}</div>
        <div class="livequizmonitor-extend-preview text-muted" data-region="extend-preview">{{previewvalue}}</div>
    </div>
</div>
