{{!
    @template quiz_livequizmonitor/student_note_modal_body

    Modal body for editing a supervision note.

    Example context (json):
    {
        "modalbody": "Notes are visible only to teachers with monitor access.",
        "textareaaria": "Supervision note",
        "content": ""
    }
}}
<div class="livequizmonitor-note-modal-body">
    <p class="text-muted mb-2"><label for="student-note-field">{{modalbody}}</label></p>
    <textarea id="student-note-field" class="form-control"
              rows="6"
              maxlength="2000"
              data-region="note-content"
              aria-label="{{textareaaria}}">{{content}}</textarea>
</div>
