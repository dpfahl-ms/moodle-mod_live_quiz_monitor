{{!
    @template quiz_livequizmonitor/student_row

    Single student row in the live quiz monitor table.

    Example context (json):
    {
        "userid": 42,
        "statusclass": "badge-info",
        "statuslabel": "In progress",
        "fullname": "Jane Student",
        "showemailcolumn": true,
        "email": "jane@example.com",
        "progresspercent": 50,
        "progresstext": "5 / 10",
        "progressbarclass": "bg-info",
        "hastimer": true,
        "timeremaining": 600,
        "timeremainingdisplay": "10:00",
        "showactionscolumn": true,
        "isblocked": false,
        "blockedflaglabel": "Blocked by one-session rule",
        "actionsmenulabel": "Actions",
        "notelabel": "Add note",
        "hasnote": false,
        "canextend": true,
        "extendrowlabel": "Extend time",
        "extendactionenabled": true,
        "attemptendat": 1700000000,
        "onesessionactive": false,
        "_mustache_lint_wrapper": true
    }
}}
{{#_mustache_lint_wrapper}}
<table class="visually-hidden" aria-hidden="true"><tbody>
{{/_mustache_lint_wrapper}}
<tr data-userid="{{userid}}">
    <td>
        <span class="badge {{statusclass}}">{{statuslabel}}</span>
    </td>
    <td>{{fullname}}</td>
    {{#showemailcolumn}}
    <td>{{email}}</td>
    {{/showemailcolumn}}
    <td data-field="progress">
        <div class="livequizmonitor-progress">
            <div class="progress" role="progressbar"
                 aria-valuenow="{{progresspercent}}" aria-valuemin="0" aria-valuemax="100"
                 aria-label="{{progresstext}}">
                <div class="progress-bar {{progressbarclass}}" style="width: {{progresspercent}}%"></div>
            </div>
            {{#progresstext}}
            <small class="livequizmonitor-progress-label text-muted">{{progresstext}}</small>
            {{/progresstext}}
        </div>
    </td>
    <td>
        {{#hastimer}}
        <span class="livequizmonitor-timer" data-field="timer" data-timeremaining="{{timeremaining}}">{{timeremainingdisplay}}</span>
        {{/hastimer}}
        {{^hastimer}}
        <span class="livequizmonitor-timer" data-field="timer">—</span>
        {{/hastimer}}
    </td>
    {{#showactionscolumn}}
    <td class="livequizmonitor-actions" data-field="actions">
        <div class="livequizmonitor-actions-inner">
            {{> quiz_livequizmonitor/row_action_menu }}
            {{#isblocked}}
            <i class="fa-solid fa-flag livequizmonitor-blocked-flag"
               title="{{blockedflaglabel}}"
               aria-hidden="true"></i>
            {{/isblocked}}
        </div>
    </td>
    {{/showactionscolumn}}
</tr>
{{#_mustache_lint_wrapper}}
</tbody></table>
{{/_mustache_lint_wrapper}}
