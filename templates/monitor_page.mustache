{{!
    @template quiz_livequizmonitor/monitor_page

    Root page template for the live quiz monitor report.

    Example context (json):
    {
        "cmid": 10,
        "groupid": 0,
        "showemailcolumn": true,
        "showactionscolumn": true,
        "lastupdatedprefix": "Last updated:",
        "extendrowlabel": "Extend time",
        "notesaddlabel": "Add note",
        "noteseditlabel": "Edit note",
        "unblocklabel": "Unblock",
        "blockedflaglabel": "Blocked",
        "actionsmenulabel": "Actions",
        "canextend": true,
        "onesessionactive": false,
        "canunblock": false,
        "quizname": "Midterm quiz",
        "liveindicator": "Live",
        "updatedattext": "Last updated: 12:00",
        "bulkextenddisabled": false,
        "bulkextendlabel": "Extend all",
        "staleindicator": "Data may be stale",
        "hasstudents": true,
        "emptycohort": "No students in this cohort.",
        "summary": {
            "notstarted": {"label": "Not started", "count": 1, "percent": 25, "statusclass": "border-secondary"},
            "inprogress": {"label": "In progress", "count": 2, "percent": 50, "statusclass": "border-info"},
            "completed": {"label": "Completed", "count": 1, "percent": 25, "statusclass": "border-success"}
        },
        "filter": {
            "chipsgrouplabel": "Filter students",
            "searchplaceholder": "Search students",
            "clearlabel": "Clear filters",
            "chips": []
        },
        "filterempty": "No students match the current filters.",
        "tableheaders": {
            "status": "Status",
            "student": "Student",
            "email": "Email",
            "progress": "Progress",
            "timeremaining": "Time remaining",
            "actions": "Actions"
        },
        "students": []
    }
}}
<div class="livequizmonitor-root" data-region="live-quiz-monitor"
     data-cmid="{{cmid}}"
     data-groupid="{{groupid}}"
     data-show-email="{{#showemailcolumn}}1{{/showemailcolumn}}{{^showemailcolumn}}0{{/showemailcolumn}}"
     data-show-actions="{{#showactionscolumn}}1{{/showactionscolumn}}{{^showactionscolumn}}0{{/showactionscolumn}}"
     data-lastupdated-prefix="{{lastupdatedprefix}}"
     data-extend-row-label="{{extendrowlabel}}"
     data-notes-add-label="{{notesaddlabel}}"
     data-notes-edit-label="{{noteseditlabel}}"
     data-unblock-label="{{unblocklabel}}"
     data-blocked-flag-label="{{blockedflaglabel}}"
     data-actions-menu-label="{{actionsmenulabel}}"
     data-canextend="{{#canextend}}1{{/canextend}}{{^canextend}}0{{/canextend}}"
     data-onesession-active="{{#onesessionactive}}1{{/onesessionactive}}{{^onesessionactive}}0{{/onesessionactive}}"
     data-canunblock="{{#canunblock}}1{{/canunblock}}{{^canunblock}}0{{/canunblock}}">

    <div class="livequizmonitor-header d-flex flex-wrap align-items-center justify-content-between mb-3">
        <div>
            <h2 class="livequizmonitor-title mb-1">{{quizname}}</h2>
            <div class="livequizmonitor-meta text-muted small">
                <span class="livequizmonitor-live badge badge-success mr-2">{{liveindicator}}</span>
                <span data-region="last-updated">{{updatedattext}}</span>
            </div>
        </div>
        <div class="livequizmonitor-header-actions d-flex align-items-center gap-2">
            {{#canextend}}
            <button type="button"
                    class="btn btn-primary"
                    data-action="extend-bulk"
                    {{#bulkextenddisabled}}disabled{{/bulkextenddisabled}}>
                {{bulkextendlabel}}
            </button>
            {{/canextend}}
            <div class="livequizmonitor-stale alert alert-warning py-1 px-2 mb-0 d-none" data-region="stale-indicator" role="status">
                {{staleindicator}}
            </div>
        </div>
    </div>

    <div class="alert alert-info {{#hasstudents}}d-none{{/hasstudents}}" data-region="empty-cohort" role="status">
        {{emptycohort}}
    </div>

    <div data-region="cohort-content" class="{{^hasstudents}}d-none{{/hasstudents}}">
        {{> quiz_livequizmonitor/summary_tiles }}
        {{> quiz_livequizmonitor/filter_toolbar }}
        {{> quiz_livequizmonitor/student_table }}
    </div>
</div>

{{#js}}
require(['quiz_livequizmonitor/monitor'], function(Monitor) {
    Monitor.init('[data-region="live-quiz-monitor"]');
});
{{/js}}
